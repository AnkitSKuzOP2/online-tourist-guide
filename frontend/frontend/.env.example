# ─── Frontend Environment Variables ──────────────────────────────────────────
# Copy this file to .env for local dev. Add the production value in Vercel dashboard.

# Backend API base URL
# Local:
REACT_APP_API_URL=http://localhost:4000/api/v1
# Production (set this in Vercel Dashboard > Project > Settings > Environment Variables):
# REACT_APP_API_URL=https://your-backend.onrender.com/api/v1

# Google Maps API key (if used)
REACT_APP_GOOGLE_MAPS_KEY=your_google_maps_api_key
